{
  "name": "afeys/flphpapp",
  "description": "Simple application runner for PHP",
  "keywords": [
    "apprunner"
  ],
  "homepage": "https://github.com/afeys/flphpapp",
  "license": "MIT",
  "authors": [
    {
      "name": "Andy Feys",
      "email": "gitprojects@feys.be",
      "homepage": "http://www.feys.be"
    }
  ],
  "require": {
    "php": ">=5.4.0",
    "afeys/flphpbasics": "^1.0",
    "afeys/flphpsuperglobals": "^1.0",
    "afeys/flphpldap": "^1.0",
    "afeys/flphpdb": "^1.0.0",
    "afeys/flphpfile": "^0.5.0",
    "afeys/flphplog": "^1.0.0",
    "afeys/flphpcolors": "^0.9.2",
    "afeys/flphpmail": "^1.0.2"
  },
  "require-dev": {
    "phpunit/phpunit": "~4.0"
  },
  "support": {
    "issues": "https://github.com/afeys/flphpapp/issues",
    "source": "https://github.com/afeys/flphpapp/"
  },
  "autoload": {
    "psr-4": { "flphpapp\\": "src/" },
    "files": ["src/init.php"]
  },
  "autoload-dev": {
    "classmap": [  ]
  }
}